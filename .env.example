# Blockchain / RPC
RPC_URL=
RPC_WS_URL=
CHAIN_ID=137

# Wallets
EXECUTION_PRIVATE_KEY=
TREASURY_ADDRESS=

# Protocolink
PROTOCOLINK_API_KEY=

# ParaSwap / OpenOcean
PARASWAP_API_URL=https://apiv5.paraswap.io
OPENOCEAN_API_URL=https://open-api.openocean.finance/v3/polygon

# Database
DATABASE_URL=

# Risk / thresholds
DEFAULT_MIN_PROFIT_USD=5
DEFAULT_MIN_SPREAD_BPS=30
MAX_POSITION_SIZE_USD=1000
MAX_CONCURRENT_TRADES=3
MAX_SLIPPAGE_BPS=50

# Circuit breaker
MAX_CONSECUTIVE_LOSSES=3
MAX_GAS_PRICE_GWEI=300
CIRCUIT_BREAKER_COOLDOWN_MS=900000

# Sweep
SWEEP_ENABLED=true
SWEEP_MIN_BALANCE_USD=20
SWEEP_KEEP_GAS_RESERVE_USD=10
SWEEP_TARGET_SYMBOL=USDC
SWEEP_DUST_THRESHOLD_USD=0.01

# Alerts (optional --- leave blank to fall back to logs only)
DISCORD_WEBHOOK_URL=

# Scanner
SCAN_INTERVAL_MS=3000
LOG_LEVEL=info
NODE_ENV=production

ZEROEX_API_KEY=your-0x-api-key